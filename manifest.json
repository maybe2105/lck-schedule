{
  "manifest_version": 3,
  "name": "LoL Esports Schedule",
  "version": "1.2.0",
  "description": "LoL esports schedule widget — pick your leagues (LCK, MSI, Worlds, EWC, and more) with a Twitch caedrel live toolbar badge.",
  "permissions": ["alarms", "storage"],
  "host_permissions": [
    "https://esports-api.lolesports.com/*",
    "https://static.lolesports.com/*",
    "https://gql.twitch.tv/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LoL Esports Schedule",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
